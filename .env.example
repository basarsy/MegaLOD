############################################
# MegaLOD environment configuration
#
# Copy to .env and fill in real values:
#   cp .env.example .env
############################################

# --- Omeka S / MariaDB ---
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=megalod
DB_USER=CHANGE_ME
DB_PASSWORD=CHANGE_ME

# --- GraphDB connection ---
# Full base URL (takes precedence over HOST+PORT).
# GRAPHDB_BASE_URL=http://graphdb.example.com:7200
# Or set host and port separately:
GRAPHDB_HOST=127.0.0.1
GRAPHDB_PORT=7200
GRAPHDB_REPOSITORY=megalod

# --- GraphDB credentials (write access) ---
GRAPHDB_USERNAME=CHANGE_ME
GRAPHDB_PASSWORD=CHANGE_ME

# --- GraphDB (read-only access, optional) ---
# Falls back to write credentials if not set.
GRAPHDB_READONLY_USERNAME=
GRAPHDB_READONLY_PASSWORD=

# --- GraphDB Workbench URL (for SPARQL UI redirect) ---
GRAPHDB_WORKBENCH_URL=http://localhost:7200/

# --- MegaLOD URI strategy ---
# Canonical persistent namespace for named graphs in GraphDB.
MEGALOD_PUBLIC_BASE_URI=https://purl.org/megalod/
# Local entity base URI for IRIs within the Omeka installation.
# In production set this to your public Omeka URL, e.g. https://megalod.example.org/megalod/
MEGALOD_LOCAL_BASE_URI=http://localhost/megalod/

# --- Omeka S internal API ---
OMEKA_BASE_URL=http://localhost/api
OMEKA_KEY_IDENTITY=CHANGE_ME
OMEKA_KEY_CREDENTIAL=CHANGE_ME
